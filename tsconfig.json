{
  "extends": "@vue/tsconfig/tsconfig.json",
  "compilerOptions": {
    "sourceMap": true,
    "ignoreDeprecations": "5.0",
    // 解析非相对模块名的基准目录
    "baseUrl": ".",
    // 模块名到基于 baseUrl 的路径映射的列表
    "paths": {
      "@/*": ["./src/*"],
      "#/*": ["./types/*"]
    },
    "lib": ["esnext", "dom"],
    "types": ["@dcloudio/types", "vite/client"]
  },
  // 定义希望被编译的文件所在的目录 ** 代表任意目录 * 代表任意文件
  "include": ["src/**/*.ts", "types/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue", "vite.config.ts"]
}
